{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/vendors/layout,_N_T_/dashboard/vendors/page,_N_T_/dashboard/vendors"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/vendors/__PAGE__",
    "/dashboard/vendors",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}